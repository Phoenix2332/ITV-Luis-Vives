{
  "Storage": {
    "Type": "Json"
  },
  "Repository": {
    "Type": "Dapper",
    "Directory": "data",
    "ConnectionString": "Data Source=data/itv.db",
    "DropData": true,
    "SeedData": true,
    "UseLogicalDelete": true
  },
  "Cache": {
    "Size": 5
  },
  "Backup": {
    "Directory": "backup",
    "Format": "Json"
  },
  "Reports": {
    "Directory": "reports"
  },
  "Development": {
    "Enabled": true
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": "Debug",
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:HH:mm:ss.fff} [{Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "log/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff} [{Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  }
}